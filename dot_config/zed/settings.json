// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "ui_font_family": "HackGen",
  "buffer_line_height": "comfortable",
  "buffer_font_weight": 500.0,
  "text_rendering_mode": "grayscale",
  "agent": {
    "default_model": {
      "provider": "copilot_chat",
      "model": "claude-haiku-4.5",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "outline_panel": {
    "button": true,
    "file_icons": true,
    "git_status": true,
  },
  "active_pane_modifiers": {
    "inactive_opacity": 1.0,
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false,
  },
  "terminal": {
    "dock": "bottom",
    "font_size": 10.5,
    "font_family": "HackGen Console NF",
    "font_fallbacks": ["Menlo", "Monaco", "Courier New"],
  },
  "base_keymap": "VSCode",
  "multi_cursor_modifier": "cmd_or_ctrl",
  "file_types": {
    "Plan Text": [".gitcommit_template"],
    "YAML": [".git_consistent"],
    "TOML": ["*.toml.tmpl"],
    "Shell Script": ["*.zsh.tmpl"],
  },
  "auto_indent_on_paste": false,
  "show_whitespaces": "all",
  "ensure_final_newline_on_save": true,
  "wrap_guides": [80, 160],
  "soft_wrap": "none",
  "tab_size": 2,
  "ui_font_size": 16,
  "buffer_font_size": 10.5,
  "buffer_font_family": "HackGen",
  "buffer_font_fallbacks": ["Menlo", "Monaco", "Courier New"],
  "theme": {
    "mode": "dark",
    "light": "One Light",
    "dark": "One Dark",
  },
  "edit_predictions": {
    "provider": "zed",
  },
}
